#include <Arduino.h>
#include <arduinoFFT.h>
#include <Freenove_4WD_Car_For_ESP32.h>

// MAX9814 Analog Pin Setup (Pin 15 is on ADC2)
#define MIC_PIN 15 

// Sampling Setup
#define SAMPLES 512              // Must be a power of 2
#define SAMPLING_FREQUENCY 10000 // Maximum 10kHz for standard analogRead loop

unsigned int sampling_period_us;
unsigned long microseconds;

// Fourier arrays
double vReal[SAMPLES];
double vImag[SAMPLES];

ArduinoFFT<double> FFT = ArduinoFFT<double>(vReal, vImag, SAMPLES, SAMPLING_FREQUENCY);

void setup() {
  // Serial output for USB cable monitoring
  Serial.begin(115200);

  // Calculate the time to wait between each sample (in microseconds)
  sampling_period_us = round(1000000 * (1.0 / SAMPLING_FREQUENCY));

  // Motors Setup
  PCA9685_Setup();
}

void loop() {
  float signalMax = 0, signalMin = 4095; // ESP32 12-bit ADC max value

  // 1. Collect Samples for Volume and Frequency
  for (int i = 0; i < SAMPLES; i++) {
    microseconds = micros();
    
    int sample = analogRead(MIC_PIN);
    vReal[i] = sample;
    vImag[i] = 0;

    // Track Max/Min for Volume calculation
    if (sample > signalMax) signalMax = sample;
    if (sample < signalMin) signalMin = sample;

    // Wait for the next sampling period to maintain accurate frequency
    while (micros() < (microseconds + sampling_period_us)) {
      // blocking loop to hold timing
    }
  }

  // 2. Calculate Volume (Amplitude / Voltage)
  float peakToPeak = signalMax - signalMin;
  float voltage = (peakToPeak * 3.3) / 4095.0;

  // 3. Calculate Frequency (FFT)
  FFT.windowing(FFTWindow::Hamming, FFTDirection::Forward);
  FFT.compute(FFTDirection::Forward);
  
  // Extract loudest frequency and its magnitude
  double loudestFreq = 0, loudestVol = 0;
  FFT.majorPeak(&loudestFreq, &loudestVol);

  // Print Data to Serial Monitor (via USB)
  Serial.print("Volume (V): ");
  Serial.print(voltage);
  Serial.print("  |  Loudest Freq: ");
  Serial.print(loudestFreq);
  Serial.println(" Hz");

  // 4. Translation to Movement
  // Noise gate: Only move if the voltage jump is above background noise (e.g., 0.5V)
  if(voltage > 0.5 && loudestFreq > 439 && loudestFreq < 3520) {
    // Case 1: Between A4 and A5 -> turns right
    if(loudestFreq <= 880 && loudestFreq >= 440){
      double rightSpeed = 750+(-750*(loudestFreq/440-2));
      Motor_Move(-rightSpeed, -rightSpeed, rightSpeed, rightSpeed);
    }
    // Case 2: Between A6 and A7 -> turns left
    else if (loudestFreq >= 1760 ){
      double leftSpeed = 750+(750*(loudestFreq/1760-1));
      Motor_Move(2*leftSpeed, leftSpeed, -leftSpeed, -2*leftSpeed);
    }
    // Case 3: Between A5 and A6 -> goes straight
    else{
      double moveSpeed = 1500+(-750*abs(loudestFreq/1320-1));
      Motor_Move(moveSpeed, moveSpeed, moveSpeed, moveSpeed); 
    }
  } 
  // Stop the cart if the sound is below the threshold
  else {Motor_Move(0, 0, 0, 0);}
}
